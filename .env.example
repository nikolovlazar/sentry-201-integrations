# Copy this file to `.env.local` and fill in your real values.
# `.env.local` is gitignored — never commit secrets.

# ── Required for events to reach Sentry ──
# Found in: Sentry → Settings → Projects → [your project] → Client Keys (DSN)
# This single (public) DSN powers all three runtimes: browser, server, edge.
NEXT_PUBLIC_SENTRY_DSN=

# Optional: a separate server/edge DSN. If unset, the server falls back to
# NEXT_PUBLIC_SENTRY_DSN above, so you usually don't need this.
# SENTRY_DSN=

# ── Required for source map upload + releases on `next build` ──
# These power suspect commits and GitHub stack-trace line-linking.
# Create an auth token at: Sentry → Settings → Auth Tokens (needs project:releases scope)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
